# Dependencies
/node_modules
/jspm_packages/

# Production build files
/build/
/dist/
/tmp/

# Environment variables
.env
.env.*
!.env.example # Allow an example file to be committed

# Testing and coverage
/coverage/
.nyc_output/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor and OS files (often best in a global gitignore)
.DS_Store # macOS
.vscode/ # VS Code configuration
.idea/ # IntelliJ IDEA
.project
.classpath